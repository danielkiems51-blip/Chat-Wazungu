# M-PESA Daraja API Configuration Example
# Copy this file to '.env' and fill in your actual credentials.

# Environment: 'sandbox' (for developer testing) or 'production' (for real money payments)
MPESA_ENV=sandbox

# Your M-PESA Daraja App credentials
# Register on developer.safaricom.co.ke to obtain these.
MPESA_CONSUMER_KEY=YOUR_CONSUMER_KEY_HERE
MPESA_CONSUMER_SECRET=YOUR_CONSUMER_SECRET_HERE

# M-PESA Business Details (Lipa Na M-PESA)
# Default Sandbox Shortcode is '174379'
MPESA_BUSINESS_SHORTCODE=174379

# Lipa Na M-PESA Online Passkey
# Default Sandbox Passkey is 'bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919'
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Publicly accessible URL to receive transaction status updates (Callback hook)
# For local testing, use ngrok or similar. For production, use your deployed Render domain.
# Format: https://yourdomain.com/api/mpesa/callback
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
